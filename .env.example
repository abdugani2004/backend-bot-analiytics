NODE_ENV=development
APP_NAME=telegram-bot-analytics-backend
LOG_LEVEL=info
AWS_REGION=us-east-1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/telegram_analytics
TOKEN_HASH_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173
DEFAULT_TIMEZONE=UTC
HEALTH_DEGRADED_UPTIME_PCT=99
HEALTH_DEGRADED_ERROR_RATE=5
TOKEN_ENCRYPTION_SECRET=replace-with-a-32-byte-secret
TELEGRAM_WEBHOOK_BASE_URL=https://your-api-domain.example.com
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
